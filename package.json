  "scripts": {
    "dev": "next dev",
    "build": "npm run build:registry && npm run build:forms-registry && npm run build:tables-registry && npm run build:kanban-registry && npm run build:chart-ui-lab-sources && npm run build:variants-registry && next build",
    "start": "next start",
    "lint": "eslint",
    "build:registry": "tsx scripts/build-registry.ts",
    "build:forms-registry": "tsx scripts/generate-registry.ts --ts",
    "build:tables-registry": "tsx scripts/build-tables-registry.ts",
    "build:kanban-registry": "tsx scripts/build-kanban-registry.ts",
    "build:chart-ui-lab-sources": "tsx scripts/embed-chart-ui-lab-sources.ts",
    "build:variants-registry": "tsx scripts/build-variants-registry.ts",
    "build:cli": "cd afnoui-cli && npm run build",
    "verify:theme-export-sync": "node scripts/verify-theme-export-sync.mjs",
    "validate:variants": "tsx scripts/validate-installed-variants.ts",
    "verify:forms-registry": "node scripts/verify-forms-registry-sync.mjs",
    "verify:tables-registry": "node scripts/verify-tables-registry-sync.mjs",
    "verify:kanban-registry": "node scripts/verify-kanban-registry-sync.mjs",
    "verify": "npm run verify:forms-registry && npm run verify:tables-registry && npm run verify:kanban-registry && npm run verify:theme-export-sync && npm run build:chart-ui-lab-sources && npx tsc --noEmit && npm run lint && npm run test && npm run build:cli && npm run validate:variants",
    "verify:quick": "npm run verify:forms-registry && npm run verify:tables-registry && npm run verify:kanban-registry && npm run verify:theme-export-sync && npm run build:chart-ui-lab-sources && npx tsc --noEmit && npm run lint && npm run test && npm run build:cli",
    "generate:forms-registry": "tsx scripts/generate-registry.ts --ts",
    "generate:tables-registry": "tsx scripts/build-tables-registry.ts",
    "generate:kanban-registry": "tsx scripts/build-kanban-registry.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
