  "name": "sheet/sheet-filter",
  "category": "sheet",
  "variant": "sheet-filter",
  "files": [
    {
      "path": "components/ui/sheet/sheet-filter.tsx",
      "type": "registry:variant",
      "content": "\"use client\";\n\nimport { Filter } from \"lucide-react\";\nimport {\n  Sheet,\n  SheetClose,\n  SheetContent,\n  SheetDescription,\n  SheetFooter,\n  SheetHeader,\n  SheetTitle,\n  SheetTrigger,\n} from \"@/components/ui/sheet\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport { Separator } from \"@/components/ui/separator\";\n\nconst data = {\n  \"title\": \"Filters\",\n  \"description\": \"Narrow down your search results\",\n  \"categories\": [\n    \"Electronics\",\n    \"Clothing\",\n    \"Books\",\n    \"Home\"\n  ],\n  \"ratings\": [\n    \"4 stars & up\",\n    \"3 stars & up\",\n    \"2 stars & up\",\n    \"1 star & up\"\n  ]\n};\n\nexport default function SheetFilterExample() {\n  return (\n    <Sheet>\n      <SheetTrigger asChild>\n        <Button variant=\"outline\">\n          <Filter className=\"me-2 h-4 w-4\" />\n          Filters\n        </Button>\n      </SheetTrigger>\n      <SheetContent>\n        <SheetHeader>\n          <SheetTitle>{data.title}</SheetTitle>\n          <SheetDescription>{data.description}</SheetDescription>\n        </SheetHeader>\n        <div className=\"py-6 space-y-6\">\n          <div className=\"space-y-2\">\n            <Label>Price Range</Label>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <Input placeholder=\"Min\" type=\"number\" />\n              <Input placeholder=\"Max\" type=\"number\" />\n            </div>\n          </div>\n          <Separator />\n          <div className=\"space-y-2\">\n            <Label>Category</Label>\n            <div className=\"space-y-2\">\n              {data.categories.map((cat) => (\n                <div key={cat} className=\"flex items-center gap-2\">\n                  <input type=\"checkbox\" id={cat} className=\"rounded\" />\n                  <label htmlFor={cat} className=\"text-sm\">{cat}</label>\n                </div>\n              ))}\n            </div>\n          </div>\n          <Separator />\n          <div className=\"space-y-2\">\n            <Label>Rating</Label>\n            <div className=\"space-y-2\">\n              {data.ratings.map((rating) => (\n                <div key={rating} className=\"flex items-center gap-2\">\n                  <input type=\"radio\" name=\"rating\" id={rating} />\n                  <label htmlFor={rating} className=\"text-sm\">{rating}</label>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n        <SheetFooter>\n          <Button variant=\"outline\" className=\"flex-1\">Clear All</Button>\n          <SheetClose asChild>\n            <Button className=\"flex-1\">Apply Filters</Button>\n          </SheetClose>\n        </SheetFooter>\n      </SheetContent>\n    </Sheet>\n  );\n}\n"
    }
  ]
}