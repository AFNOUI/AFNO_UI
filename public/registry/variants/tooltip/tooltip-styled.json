{
  "name": "tooltip/tooltip-styled",
  "category": "tooltip",
  "variant": "tooltip-styled",
  "files": [
    {
      "path": "components/ui/tooltip/tooltip-styled.tsx",
      "type": "registry:variant",
      "content": "\"use client\";\n\nimport { Tooltip, TooltipContent, TooltipTrigger } from \"@/components/ui/tooltip\";\nimport { Button } from \"@/components/ui/button\";\n\nconst data = {\n  \"variants\": [\n    {\n      \"id\": \"default\",\n      \"label\": \"Default\",\n      \"text\": \"Default tooltip style\",\n      \"kind\": \"default\"\n    },\n    {\n      \"id\": \"dark\",\n      \"label\": \"Dark Theme\",\n      \"text\": \"Dark tooltip\",\n      \"kind\": \"dark\"\n    },\n    {\n      \"id\": \"primary\",\n      \"label\": \"Primary Color\",\n      \"text\": \"Primary styled\",\n      \"kind\": \"primary\"\n    }\n  ]\n};\n\nexport default function TooltipStyledExample() {\n  return (\n    <div className=\"flex flex-wrap gap-4 justify-center py-4\">\n      <Tooltip>\n        <TooltipTrigger asChild>\n          <Button variant=\"outline\">{data.variants[0].label}</Button>\n        </TooltipTrigger>\n        <TooltipContent showArrow>\n          <p>{data.variants[0].text}</p>\n        </TooltipContent>\n      </Tooltip>\n\n      <Tooltip>\n        <TooltipTrigger asChild>\n          <Button variant=\"outline\">{data.variants[1].label}</Button>\n        </TooltipTrigger>\n        <TooltipContent\n          className=\"bg-foreground text-background border-foreground\"\n          showArrow\n          arrowClassName=\"fill-foreground\"\n        >\n          <p>{data.variants[1].text}</p>\n        </TooltipContent>\n      </Tooltip>\n\n      <Tooltip>\n        <TooltipTrigger asChild>\n          <Button variant=\"outline\">{data.variants[2].label}</Button>\n        </TooltipTrigger>\n        <TooltipContent\n          className=\"bg-primary text-primary-foreground border-primary\"\n          showArrow\n          arrowClassName=\"fill-primary\"\n        >\n          <p>{data.variants[2].text}</p>\n        </TooltipContent>\n      </Tooltip>\n    </div>\n  );\n}\n"
    }
  ]
}