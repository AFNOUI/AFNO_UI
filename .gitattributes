# Normalize all text files to LF in the repo (and on checkout).
# Prevents the CRLF churn that Windows/AI-export tooling can introduce.
* text=auto eol=lf

# Binary assets: never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
