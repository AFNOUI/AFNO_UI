      "code": "import { useForm } from "react-hook-form";
import { zodResolver } from "@hookform/resolvers/zod";
import { Form } from "../components/ui/form";
import { Button } from "../components/ui/button";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "../components/ui/card";
import { TextField } from "../components/forms/react-hook-form/fields/TextField";
import { SelectField } from "../components/forms/react-hook-form/fields/SelectField";
import { AsyncSelectField } from "../components/forms/react-hook-form/fields/AsyncSelectField";
import { MultiselectField } from "../components/forms/react-hook-form/fields/MultiselectField";
import { CheckboxField } from "../components/forms/react-hook-form/fields/CheckboxField";
import { DateField } from "../components/forms/react-hook-form/fields/DateField";
import { TextareaField } from "../components/forms/react-hook-form/fields/TextareaField";
import { formService } from "./formService";
import { formSchema } from "./formSchema";

export default function MyFormPage() {
  const SUBMIT_EXCLUDED = new Set<string>();

  const form = useForm({
    resolver: zodResolver(formSchema),
    defaultValues: {
        "name": "",
        "age": "",
        "country": "",
        "city": "",
        "tags": [],
        "agree": false,
        "dob": "",
        "bio": ""
    },
    mode: "onSubmit",
  });

  const onSubmit = form.handleSubmit(async (data) => {
    const payload = { ...data } as Record<string, unknown>;
    for (const name of SUBMIT_EXCLUDED) {
      delete payload[name];
      const p = \`\${name}__\`;
      for (const k of Object.keys(payload)) {
        if (k.startsWith(p)) delete payload[k];
      }
    }
    await formService.submitForm(payload);
  });

  return (
    <div className="container mx-auto py-8 max-w-3xl">
      <Form {...form}>
        <form onSubmit={onSubmit} className="space-y-6">
            <Card>
              <CardHeader>
                <CardTitle>Identity</CardTitle>
              </CardHeader>
              <CardContent className="grid gap-4">
              <TextField config={{
                  "name": "name",
                  "type": "text",
                  "label": "Name",
                  "required": true,
                  "minLength": 2
                }} />
              <TextField config={{
                  "name": "age",
                  "type": "number",
                  "label": "Age",
                  "min": 0,
                  "max": 120
                }} />
              <SelectField config={{
                  "name": "country",
                  "type": "select",
                  "label": "Country",
                  "options": [
                    {
                      "value": "us",
                      "label": "US"
                    },
                    {
                      "value": "np",
                      "label": "NP"
                    }
                  ],
                  "required": true
                }} />
              <AsyncSelectField config={{
                  "name": "city",
                  "type": "asyncselect",
                  "label": "City",
                  "api": {
                    "url": "https://api.example.com/cities",
                    "method": "GET",
                    "responseMapping": {
                      "dataPath": "data",
                      "labelKey": "name",
                      "valueKey": "id"
                    }
                  }
                }} />
              <MultiselectField config={{
                  "name": "tags",
                  "type": "multiselect",
                  "label": "Tags",
                  "options": [
                    {
                      "value": "a",
                      "label": "A"
                    }
                  ]
                }} />
              <CheckboxField config={{
                  "name": "agree",
                  "type": "checkbox",
                  "label": "Agree",
                  "required": true
                }} />
              <DateField config={{
                  "name": "dob",
                  "type": "date",
                  "label": "Date of birth"
                }} />
              <TextareaField config={{
                  "name": "bio",
                  "type": "textarea",
                  "label": "Bio",
                  "maxLength": 500
                }} />
              </CardContent>
            </Card>

            <Button type="submit" disabled={form.formState.isSubmitting}>
              {form.formState.isSubmitting ? "Submitting..." : "Submit"}
            </Button>
        </form>
      </Form>
    </div>
  );
}
",
