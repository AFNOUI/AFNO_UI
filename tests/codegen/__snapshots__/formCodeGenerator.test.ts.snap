    {
      "code": "import { useState } from "react";
import { useForm } from "@tanstack/react-form";
import { Button } from "../components/ui/button";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "../components/ui/card";
import { Alert, AlertDescription } from "../components/ui/alert";
import { AlertCircle, X } from "lucide-react";
import { TanstackFormProvider } from "../components/forms/tanstack-forms/TanstackFormContext";
import { TextField } from "../components/forms/tanstack-forms/fields/TextField";
import { SelectField } from "../components/forms/tanstack-forms/fields/SelectField";
import { AsyncSelectField } from "../components/forms/tanstack-forms/fields/AsyncSelectField";
import { MultiselectField } from "../components/forms/tanstack-forms/fields/MultiselectField";
import { CheckboxField } from "../components/forms/tanstack-forms/fields/CheckboxField";
import { DateField } from "../components/forms/tanstack-forms/fields/DateField";
import { TextareaField } from "../components/forms/tanstack-forms/fields/TextareaField";
import { formService } from "./formService";
import { formSchema } from "./formSchema";

export default function MyFormPage() {
  const [globalError, setGlobalError] = useState<string | null>(null);
  const SUBMIT_EXCLUDED = new Set<string>();

  const form = useForm({
    defaultValues: {
        "name": "",
        "age": "",
        "country": "",
        "city": "",
        "tags": [],
        "agree": false,
        "dob": "",
        "bio": ""
    },
    validators: {
      onSubmit: formSchema,
    },
    onSubmit: async ({ value }) => {
      setGlobalError(null);
      try {
        const payload = { ...(value as Record<string, unknown>) };
        for (const name of SUBMIT_EXCLUDED) {
          delete payload[name];
          const p = \`\${name}__\`;
          for (const k of Object.keys(payload)) {
            if (k.startsWith(p)) delete payload[k];
          }
        }
        await formService.submitForm(payload);
      } catch (error: any) {
        setGlobalError(error?.message || "An unexpected error occurred");
      }
    },
  });

  return (
    <div className="container mx-auto py-8 max-w-3xl">
      <TanstackFormProvider value={{ form, values: form.state.values as Record<string, unknown> }}>
        <form
          onSubmit={(e) => { e.preventDefault(); form.handleSubmit(); }}
          className="space-y-6"
        >
          {globalError && (
            <Alert variant="destructive">
              <AlertCircle className="h-4 w-4" />
              <AlertDescription className="flex items-center justify-between">
                {globalError}
                <button type="button" onClick={() => setGlobalError(null)}><X className="h-4 w-4" /></button>
              </AlertDescription>
            </Alert>
          )}

            <Card>
              <CardHeader>
                <CardTitle>Identity</CardTitle>
              </CardHeader>
              <CardContent className="grid gap-4">
              <TextField config={{
                  "name": "name",
                  "type": "text",
                  "label": "Name",
                  "required": true,
                  "minLength": 2
                }} />
              <TextField config={{
                  "name": "age",
                  "type": "number",
                  "label": "Age",
                  "min": 0,
                  "max": 120
                }} />
              <SelectField config={{
                  "name": "country",
                  "type": "select",
                  "label": "Country",
                  "options": [
                    {
                      "value": "us",
                      "label": "US"
                    },
                    {
                      "value": "np",
                      "label": "NP"
                    }
                  ],
                  "required": true
                }} />
              <AsyncSelectField config={{
                  "name": "city",
                  "type": "asyncselect",
                  "label": "City",
                  "api": {
                    "url": "https://api.example.com/cities",
                    "method": "GET",
                    "responseMapping": {
                      "dataPath": "data",
                      "labelKey": "name",
                      "valueKey": "id"
                    }
                  }
                }} />
              <MultiselectField config={{
                  "name": "tags",
                  "type": "multiselect",
                  "label": "Tags",
                  "options": [
                    {
                      "value": "a",
                      "label": "A"
                    }
                  ]
                }} />
              <CheckboxField config={{
                  "name": "agree",
                  "type": "checkbox",
                  "label": "Agree",
                  "required": true
                }} />
              <DateField config={{
                  "name": "dob",
                  "type": "date",
                  "label": "Date of birth"
                }} />
              <TextareaField config={{
                  "name": "bio",
                  "type": "textarea",
                  "label": "Bio",
                  "maxLength": 500
                }} />
              </CardContent>
            </Card>

          <form.Subscribe selector={(state) => state.isSubmitting}>
            {(isSubmitting) => (
              <Button type="submit" disabled={isSubmitting}>
                {isSubmitting ? "Submitting..." : "Submit"}
              </Button>
            )}
          </form.Subscribe>
        </form>
      </TanstackFormProvider>
    </div>
  );
}
",
      "language": "tsx",
      "name": "MyFormPage.tsx",
      "path": "pages/MyFormPage.tsx",
    },
  ],
}
`;

